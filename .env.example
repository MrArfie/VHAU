# The app reads the contract address from src/config.ts (no .env needed for the React app).
# Copy this file to .env only if you use Hardhat to deploy (see below).

# Optional: for deploying WITHOUT MetaMask using Hardhat (run: npx hardhat run scripts/deploy.cjs --network sepolia --config hardhat.config.cjs).
# Get Sepolia ETH from https://sepoliafaucet.com first. Never commit .env or share your private key.
# PRIVATE_KEY=0xYourWalletPrivateKey
# SEPOLIA_RPC_URL=https://rpc.sepolia.org
